# Kubeport eval-stack configuration — copy to .env to override defaults.
# All values have sensible defaults; the file is optional for a local demo.

# --- Bench site -------------------------------------------------------------
SITE_NAME=kubeport.localhost
ADMIN_PASSWORD=admin

# --- Database ---------------------------------------------------------------
MARIADB_ROOT_PASSWORD=changeme

# --- Embedded Kubernetes ----------------------------------------------------
K3S_CLUSTER_NAME=eval-k3s

# --- Host port mappings -----------------------------------------------------
# Override these if 8000 / 9000 / 6443 are taken on your machine.
BENCH_HOST_PORT=8000
BENCH_SOCKETIO_PORT=9000
K3S_HOST_PORT=6443

# --- Kubeport revision ------------------------------------------------------
# Pin to a tag for the submission build; main is the development default.
KUBEPORT_REPO=https://github.com/EsderJ10/kubeport
KUBEPORT_REF=main
